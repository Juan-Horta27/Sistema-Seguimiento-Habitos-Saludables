generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id         Int      @id @default(autoincrement())
  nombres    String
  apellidos  String
  correo     String   @unique
  contrasena String
  edad       Int?
  peso       Float?
  estatura   Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  habitos Habito[]
}

model CategoriaHabito {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  icono       String?
  createdAt   DateTime @default(now())

  habitos Habito[]
}

model Habito {
  id               Int      @id @default(autoincrement())
  usuarioId        Int
  categoriaHabitoId Int
  nombre           String
  descripcion      String?
  unidadMedida     String
  frecuencia       String   @default("diaria")
  activo           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  usuario         Usuario         @relation(fields: [usuarioId], references: [id])
  categoriaHabito CategoriaHabito @relation(fields: [categoriaHabitoId], references: [id])
  metas           Meta[]
  registros       RegistroDiario[]
  racha           Racha?
}

model Meta {
  id            Int      @id @default(autoincrement())
  habitoId      Int
  valorObjetivo Float
  descripcion   String?
  activa        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  habito Habito @relation(fields: [habitoId], references: [id])
}

model RegistroDiario {
  id              Int      @id @default(autoincrement())
  habitoId        Int
  fecha           DateTime @db.Date
  valorRegistrado Float
  metaCumplida    Boolean  @default(false)
  notas           String?
  createdAt       DateTime @default(now())

  habito Habito @relation(fields: [habitoId], references: [id])

  @@unique([habitoId, fecha])
}

model Racha {
  id          Int      @id @default(autoincrement())
  habitoId    Int      @unique
  rachaActual Int      @default(0)
  rachaMaxima Int      @default(0)
  updatedAt   DateTime @updatedAt

  habito Habito @relation(fields: [habitoId], references: [id])
}
